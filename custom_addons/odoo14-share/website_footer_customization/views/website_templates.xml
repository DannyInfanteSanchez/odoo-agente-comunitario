<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <template id="assets_frontend" inherit_id="website.assets_frontend" name="Marketplace">
		<xpath expr="." position="inside">
			<link rel="stylesheet" href="/website_footer_customization/static/src/css/style.css" />
		</xpath>
	</template>


    <template id="custom_layout" inherit_id="website.layout">
        <xpath expr="//footer" position="attributes">
            <attribute name="class">footer_bg</attribute>
        </xpath>
    </template>

    <template id="custom_layout_footer_copyright" inherit_id="website.layout_footer_copyright">
        <xpath expr="//div[@class='container mt16 mb8']" position="replace">
            <div class="container mt16 mb8">
                <div class="footer_copyright text-muted" itemscope="itemscope" itemtype="http://schema.org/Organization">
                    Copyright &amp;copy; <span t-field="res_company.name" itemprop="name">Company name</span>
                </div>
            </div>
        </xpath>
    </template>


</odoo>