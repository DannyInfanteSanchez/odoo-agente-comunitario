<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
    <!-- Tarea programada para desactivar usuarios inactivos -->
        <record id="ir_cron_deactivate_inactive_users" model="ir.cron">
            <field name="name">SEG: Desactivar Usuarios Inactivos</field>
            <field name="model_id" ref="base.model_res_users"/>
            <field name="state">code</field>
            <field name="code">model.comprobar_desactivar_usuarios_inactivos()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall">False</field>
            <field name="active">True</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="nextcall" eval="(datetime.now() + timedelta(days=1)).strftime('%Y-%m-%d 02:00:00')"/>
        </record>
    </data>
</odoo>