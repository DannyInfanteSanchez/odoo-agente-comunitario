<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="password_expired" name="Password Expired">
        <t t-call="web.login_layout">
            <div class="oe_login_form">
                <h3><t t-esc="error"/></h3>
                <p>Por favor, contacte al administrador o restablezca su contraseña.</p>
                <a class="btn btn-primary" href="/web/reset_password">Restablecer contraseña</a>
            </div>
        </t>
    </template>
</odoo>