<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- VISTA TREE -->
    <record id="view_inherit_eess_tree" model="ir.ui.view">
        <field name="name">renipress.eess.tree</field>
        <field name="model">renipress.eess</field>
        <field name="inherit_id" ref="renipress.view_eess_tree"/>
        <field name="arch" type="xml">
            <field name='name' position="after">
                <field name="unidadejecutora_id"/>
            </field>
        </field>
    </record>

    <!-- VISTA FORM -->
    <record id="view_inherit_eess_form" model="ir.ui.view">
        <field name="name">renipress.eess.form</field>
        <field name="model">renipress.eess</field>
        <field name="inherit_id" ref="renipress.view_eess_form"/>
        <field name="arch" type="xml">
            <field name='name' position="after">
                <field name="unidadejecutora_id"/>
            </field>
        </field>
    </record>
</odoo>
