<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="registro_view_tree" model="ir.ui.view">
        <field name="name">Registro Comunitario</field>
        <field name="model">minsa.registro</field>
        <field name="arch" type="xml">
            <tree decoration-danger="evalua_revalida == 1">
                <field name="create_date" readonly="1"/>
                <field name="diresa_id" readonly="1"/>
                <field name="red_id" readonly="1"/>
                <field name="establecimiento_id" readonly="1"/>
                <field name="ubigeo" readonly="1"/>
                <field name="departamento_id" readonly="1"/>
                <field name="provincia_id" readonly="1"/>
                <field name="distrito_id" readonly="1"/>
                <field name="estado" readonly="1"/>
                <field name="evalua_revalida" readonly="1"/>
            </tree>
        </field>
    </record>

    <record id="registro_view_calendar" model="ir.ui.view">
        <field name="name">Registro Comunitario Calendar</field>
        <field name="model">minsa.registro</field>
        <field name="arch" type="xml">
            <calendar string="Ficha Registro" date_start="create_date">
                <field name="diresa_id"/>
                <field name="red_id"/>
                <field name="ubigeo"/>
                <field name="establecimiento_id" />
                <field name="renipress" />
                <field name="departamento_id" />
                <field name="provincia_id" />
                <field name="distrito_id" />
            </calendar>
        </field>
    </record>

    <record id="registro_view_pivot" model="ir.ui.view">
        <field name="name">Registro Comunitario Pivot</field>
        <field name="model">minsa.registro</field>
        <field name="arch" type="xml">
            <pivot>
                <field name="create_date" type="row"/>
                <field name="diresa_id" type="row"/>
                <field name="red_id" type="row"/>
                <field name="cantidad_detalle" type='measure'/>
            </pivot>
        </field>
    </record>

    <record id="registro_view_bar" model="ir.ui.view">
        <field name="name">Registro Comunitario Barras</field>
        <field name="model">minsa.registro</field>
        <field name="arch" type="xml">
            <graph type="bar">
                <field name="diresa_id"/>
                <field name="establecimiento_id" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="registro_view_form" model="ir.ui.view">
        <field name="name">Ficha de Registro</field>
        <field name="model">minsa.registro</field>
        <field name="arch" type="xml">
            <form string="Registro Comunitario">
                <header>
                    <button name="action_validar" string="Validar" type="object" class="oe_highlight" groups="minsa_regcom.group_adminregcom, base.group_erp_manager, minsa_regcom.group_diresa, minsa_regcom.group_red" attrs="{'invisible':[('estado', '=', 'validado2')]}"/>
                    <button name="action_borrador" string="Borrador" type="object" class="oe_highlight" groups="minsa_regcom.group_diresa, minsa_regcom.group_adminregcom, base.group_erp_manager" attrs="{'invisible':[('estado','!=', 'validado')]}"/>
                    <button name="action_revalidar" string="Revalidar" type="object" class="oe_highlight" groups="minsa_regcom.group_adminregcom, base.group_erp_manager, minsa_regcom.group_diresa, minsa_regcom.group_red" attrs="{'invisible':[('evalua_revalida', '=', 0)]}"/>
                    <field name="estado" widget="statusbar"/>
                </header>
                <sheet>
                    <field name="es_grupo_nacional" invisible='1'/>
                    <field name="es_grupo_diresa" invisible='1'/>
                    <field name="es_grupo_red" invisible='1'/>
                    <field name="es_grupo_establecimiento" invisible='1'/>
                    <field name="es_grupo_admin" invisible='1'/>
                    <field name="evalua_revalida" invisible='1'/>
                    <field name="name" invisible='1'/>
                    <group>
                        <group>
                            <field name="diresa_id" options="{'no_create': True, 'no_open': True}" attrs="{'readonly':['|','|','|',('estado','in', ['validado', 'validado2']),('es_grupo_establecimiento','=', True),('es_grupo_diresa','=', True),('es_grupo_red','=', True)]}"/>
                            <field name="establecimiento_id" options="{'no_create': True, 'no_open': True}" attrs="{'readonly':['|',('estado','in', ['validado', 'validado2']),('es_grupo_establecimiento','=', True)]}" context="{'diresa_id': diresa_id, 'establecimiento_id': establecimiento_id, 'from_registro': True}"/>
                            <field name="create_date" attrs="{'readonly':True}"/>
                            <field name="tipo_registro" attrs="{'readonly': True}"/>
                        </group>
                        <group>
                            <field name="tipo_archivo" attrs="{'readonly':[('estado','in', ['validado', 'validado2'])]}"/>
                            <field name="carga_documento" widget="many2many_binary" attrs="{'readonly':[('estado', 'in', ['validado', 'validado2'])], 'invisible':[('tipo_archivo','=', 'url')], 'required': [('tipo_archivo','=','adjunto')]}"/>
                            <field name="url_documento" widget="url" attrs="{'readonly':[('estado','in', ['validado', 'validado2'])], 'invisible':[('tipo_archivo','=', 'adjunto')], 'required': [('tipo_archivo','=','url')]}"/>
                            <field name="valida_date" attrs="{'readonly':True}"/>
                            <field name="revalida_date" attrs="{'readonly':True}"/>
                            <field name="evalua_revalida" attrs="{'readonly':True}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Agente Comunitario de Salud" >
                            <field name="detalle_ids" context="{'form_view_ref': 'minsa_recurso.registro_detalle_accion_view_form'}">
                                <tree widget="one2many_list">
                                    <field name="tipo_documento"/>
                                    <field name="numero_documento"/>
                                    <field name="name"/>
                                    <field name="celular"/>
                                    <field name="estado"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="registro_detalle_view_tree" model="ir.ui.view">
        <field name="name">Registro Comunitario</field>
        <field name="model">minsa.registro.detalle</field>
        <field name="arch" type="xml">
            <tree>
                <field name="create_ficha" readonly="1"/>
                <field name="diresa_id" readonly="1"/>
                <field name="red_id" readonly="1"/>
                <field name="establecimiento_id" readonly="1"/>
                <field name="ubigeo" readonly="1"/>
                <field name="departamento_id" readonly="1"/>
                <field name="provincia_id" readonly="1"/>
                <field name="distrito_id" readonly="1"/>
                <field name="numero_documento" readonly="1"/>
                <field name="name" readonly="1"/>
                <field name="fecha_inicio" readonly="1"/>
                <field name="fecha_fin" readonly="1"/>
                <field name="estado" readonly="1"/>
                <field name="registro_estado" readonly="1"/>
            </tree>
        </field>
    </record>

    <record id="registro_detalle_view_form" model="ir.ui.view">
        <field name="name">Agente Comunitario de Salud</field>
        <field name="model">minsa.registro.detalle</field>
        <field name="arch" type="xml">
            <form duplicate="0">
                <header>
                    <button 
                        name="accion_estado"
                        string="Act Estado"
                        type="object"
                        attrs="{'invisible':[('registro_estado','not in',['validado2'])]}"
                        class="oe_highlight"
                        confirm="¿Esta seguro de actualizar el estado?"
                        groups="minsa_regcom.group_renipress,minsa_regcom.group_diresa,minsa_regcom.group_red,base.group_erp_manager"
                    />
                </header>
                <sheet>
                    <group string="Datos Personales">
                        <group>
                            <field name="registro_estado" invisible="1"/>
                            <field name="agente_comunitario_id" options="{'no_create': True, 'no_open': True}" attrs="{'readonly':['|',('estado','=', 'noactivo'),('registro_estado','!=', 'borrador')]}" context="{'form_registro_agente': True}"/>
                            <field name="tipo_documento" attrs="{'readonly': True}"/>
                            <field name="numero_documento" attrs="{'readonly': True}"/>
                            <field name="name" attrs="{'readonly': True}"/>
                            <field name="celular" attrs="{'readonly': True}"/>
                        </group>
                        <group>
                            <field name="fecha_inicio" attrs="{'readonly':['|',('estado','=', 'noactivo'),('registro_estado','!=', 'borrador')]}"/>
                            <field name="fecha_fin" attrs="{'readonly':[('estado','=', 'activo')]}"/>
                            <field name="carga_documento" widget="many2many_binary" attrs="{'readonly':['|',('estado','=', 'noactivo'),('registro_estado','!=', 'borrador')], 'required': True}"/>
                            <field name="estado"/>
                            <field name="observacion" attrs="{'invisible':[('estado','=', 'activo')], 'required': False}"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

